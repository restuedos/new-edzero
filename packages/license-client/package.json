{
  "name": "@edzero/license-client",
  "version": "2.0.0",
  "description": "License activation, verification guard, and heartbeat client for EDZero",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "default": "./dist/core.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "express": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": { "optional": true },
    "@nestjs/core": { "optional": true },
    "express": { "optional": true }
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.12",
    "@nestjs/core": "^11.0.12",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "express": "^5.0.1",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
