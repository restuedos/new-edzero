# EDZero 2.0 — Local development

APP_NAME=EDZero
APP_URL=https://edzero.test
NEXT_PUBLIC_SERVER_URL=https://edzero.test
NODE_ENV=development

# Payload CMS / Site (PostgreSQL)
SITE_DB_DATABASE=site
SITE_DB_USERNAME=site
SITE_DB_PASSWORD=secret
SITE_DATABASE_URL=postgresql://site:secret@localhost:5432/site
DATABASE_URL=postgresql://site:secret@localhost:5432/site
PAYLOAD_SECRET=edzero-dev-payload-secret-change-me

# Legacy postgres (pgAdmin default DB)
DB_DATABASE=edzero
DB_USERNAME=edzero
DB_PASSWORD=secret

# Database (license server)
LICENSE_DB_DATABASE=license
LICENSE_DB_USERNAME=license
LICENSE_DB_PASSWORD=secret

# Redis
REDIS_URL=redis://localhost:6379

# Mail (Mailpit)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=noreply@edzero.test

# MinIO / S3 (Payload media uploads)
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=edzero
# Host / seed: http://localhost:9000 — Docker site container uses http://minio:9000 via AWS_ENDPOINT_INTERNAL
AWS_ENDPOINT=http://localhost:9000
AWS_ENDPOINT_INTERNAL=http://minio:9000
S3_PUBLIC_URL=https://s3.edzero.test

# pgAdmin (profile: tools)
PGADMIN_DEFAULT_EMAIL=pgadmin@example.com
PGADMIN_DEFAULT_PASSWORD=secret
PGADMIN_CONFIG_MASTER_PASSWORD="'secret'"

# Docker Compose profiles
COMPOSE_PROFILES=license,search,queue,tools

# License client (leave VERIFY_URL empty to disable enforcement locally)
# Browser/host dev: use public HTTPS URL below
LICENSE_VERIFY_URL=https://license.edzero.test/api/license/verify
# Docker site container: internal service URL (set in docker-compose.local.yml)
LICENSE_VERIFY_URL_INTERNAL=http://license-server:3001/api/license/verify
# Middleware license check loops back to the site process (Docker only)
INTERNAL_APP_URL=http://127.0.0.1:3000
LICENSE_ENFORCEMENT_ENABLED=true
LICENSE_PRODUCTION_ENVIRONMENTS=production,prod
LICENSE_LOCAL_HMAC_SECRET=local-hmac-secret-change-me
LICENSE_HEARTBEAT_ENABLED=true
LICENSE_HEARTBEAT_MAX_STALE_HOURS=24
LICENSE_REQUIRE_HTTPS=false
LICENSE_ALLOWED_HOSTS=license.edzero.test,localhost
LICENSE_REQUEST_HMAC_SECRET=
LICENSE_STATUS_FILE=storage/private/license.json
LICENSE_ENCRYPTION_PUBLIC_KEY_PATH=storage/private/license-encryption-public.rsa
LICENSE_VERIFICATION_PUBLIC_KEY_PATH=storage/private/license-verification-public.rsa

# License server
LICENSE_SERVER_PORT=3001
LICENSE_CLOCK_SKEW_SECONDS=120
LICENSE_ALLOWED_APP_URLS=https://edzero.test,http://localhost:3000
LICENSE_DECRYPT_PRIVATE_KEY_PATH=client-keys/decrypt-private.rsa
LICENSE_SIGN_PRIVATE_KEY_PATH=client-keys/sign-private.rsa
LICENSE_VERIFICATION_PUBLIC_KEY_PATH=client-keys/verification-public.rsa

# Forward ports
FORWARD_HTTP_PORT=80
FORWARD_HTTPS_PORT=443
FORWARD_SITE_PORT=3000
FORWARD_LICENSE_PORT=3001
FORWARD_DB_PORT=5432
FORWARD_LICENSE_DB_PORT=5433
FORWARD_REDIS_PORT=6379
FORWARD_PGADMIN_PORT=5050
FORWARD_REDISINSIGHT_PORT=5540
FORWARD_MAILPIT_PORT=1025
FORWARD_MAILPIT_DASHBOARD_PORT=8025
FORWARD_MINIO_PORT=9000
FORWARD_MINIO_CONSOLE_PORT=9001
FORWARD_MEILISEARCH_PORT=7700
FORWARD_RABBITMQ_PORT=5672
FORWARD_RABBITMQ_DASHBOARD_PORT=15672
